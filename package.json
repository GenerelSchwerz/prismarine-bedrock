{
  "name": "prismarine-bedrock",
  "version": "0.0.1",
  "description": "Bedrock-first bot runtime built on the Prismarine ecosystem.",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "scripts": {
    "test": "pnpm run test:static",
    "test:static": "mocha \"test/static/**/*.test.js\"",
    "test:fake-world": "mocha \"test/fake-world/**/*.test.js\"",
    "test:live": "mocha --config .mocharc.live.json \"test/live/**/*.test.js\"",
    "test:all": "pnpm run test:static && pnpm run test:fake-world && pnpm run test:live",
    "example:basic-bot": "node examples/basic-bot.js",
    "example:block-access": "node examples/block-access.js",
    "example:crafting": "node examples/crafting.js",
    "example:dig-command": "node examples/dig-command.js",
    "example:hit-command": "node examples/hit-command.js",
    "example:superflat-scan": "node examples/superflat-scan.js",
    "example:world-diagnostics": "node examples/world-diagnostics.js"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "raknet-native"
    ]
  },
  "dependencies": {
    "@nxg-org/mineflayer-physics-util": "^1.9.3",
    "@nxg-org/mineflayer-util-plugin": "^1.9.3",
    "bedrock-protocol": "^3.55.0",
    "minecraft-data": "^3.109.1",
    "mineflayer-crafting-util": "^0.5.0",
    "mineflayer-pathfinder": "^2.4.5",
    "prismarine-block": "^1.23.0",
    "prismarine-chat": "^1.13.0",
    "prismarine-chunk": "github:GenerelSchwerz/prismarine-chunk#bedrock-1.26-compat",
    "prismarine-entity": "^2.6.0",
    "prismarine-item": "^1.18.0",
    "prismarine-nbt": "^2.8.0",
    "prismarine-recipe": "github:GenerelSchwerz/prismarine-recipe#bedrock-fix",
    "prismarine-registry": "^1.12.0",
    "prismarine-windows": "^2.10.0",
    "prismarine-world": "^3.7.0",
    "vec3": "^0.2.0"
  },
  "devDependencies": {
    "mocha": "^11.7.5"
  }
}
